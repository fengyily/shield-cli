{
  "name": "shield-cli-vscode",
  "displayName": "Shield CLI",
  "description": "VS Code extension for Shield CLI - Access any internal service from your browser",
  "version": "0.1.0",
  "publisher": "fengyily",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shield.startService",
        "title": "Shield: Start Service"
      },
      {
        "command": "shield.stopService",
        "title": "Shield: Stop Service"
      },
      {
        "command": "shield.openWebUI",
        "title": "Shield: Open Web UI"
      },
      {
        "command": "shield.connectSSH",
        "title": "Shield: Connect SSH"
      },
      {
        "command": "shield.connectRDP",
        "title": "Shield: Connect RDP"
      },
      {
        "command": "shield.connectHTTP",
        "title": "Shield: Connect HTTP"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shield-view",
          "title": "Shield CLI",
          "icon": "resources/shield-icon.svg"
        }
      ]
    },
    "views": {
      "shield-view": [
        {
          "id": "shield-sidebar",
          "name": "Shield CLI"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.80.0",
    "@vscode/test-electron": "^2.3.4",
    "typescript": "^5.1.6"
  }
}
